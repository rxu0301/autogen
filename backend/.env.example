# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Ollama (local LLM inference engine) ──────────────────────────────────────
# Docker Compose 환경에서는 서비스명(ollama)을 사용합니다.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# ── Pinecone (cloud vector DB) ────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=shortform-content

# ── ChromaDB (local vector DB) ────────────────────────────────────────────────
# Docker Compose 환경에서는 서비스명(chromadb)을 사용합니다.
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── CORS ──────────────────────────────────────────────────────────────────────
# 쉼표로 구분된 허용 오리진 목록
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
