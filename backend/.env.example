# 앱 환경
APP_ENV=development
LOG_LEVEL=INFO

# Ollama (로컬 LLM — 스크립트/썸네일 프롬프트 생성)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# 네이버 뉴스 API (한국어 뉴스 검색 — 권장)
# https://developers.naver.com/apps/#/register
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# NewsAPI.org (영문/글로벌 뉴스 — 선택)
# https://newsapi.org/register
NEWSAPI_KEY=

# ChromaDB (라이브러리 저장소)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# 팩트체크 설정
FACTCHECK_ENABLED=true       # 팩트체크 활성화 (false로 끄면 모든 뉴스 통과)
FACTCHECK_MIN_SCORE=30       # 이 점수 미만 뉴스 제외 (0~100, 기본 30)
FACTCHECK_USE_LLM=true       # LLM 콘텐츠 분석 사용 여부

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
